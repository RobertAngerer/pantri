{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pantri-web",
  "compatibility_date": "2025-04-18",
  "assets": {
    "directory": "./build",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "pantri.rawbangerer.com", "custom_domain": true }
  ]
}
